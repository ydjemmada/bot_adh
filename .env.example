# Your Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Numeric recipient chat ID. Do not use the bot id from TELEGRAM_BOT_TOKEN.
# Only this chat can use /start, /status, and /check.
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional settings
CHECK_INTERVAL_SECONDS=600
CHECK_TIMEOUT_SECONDS=90
API_CONNECT_TIMEOUT_SECONDS=6
API_TIMEOUT_SECONDS=20
API_RETRIES=3
API_RETRY_DELAY_SECONDS=2
API_FORCE_IPV4=true
GOTO_TIMEOUT_SECONDS=45
SELECTOR_TIMEOUT_SECONDS=30
NAVIGATION_RETRIES=3
FIRST_CHECK_DELAY_SECONDS=180
TARGET_URL=https://adhahi.dz/register
WILAYA_QUOTAS_API_URL=https://adhahi.dz/api/v1/public/wilaya-quotas
WILAYA_QUOTAS_API_URLS=https://adhahi.dz/api/v1/public/wilaya-quotas,https://www.adhahi.dz/api/v1/public/wilaya-quotas
BROWSER_FALLBACK_ENABLED=false
PORT=

# Optional browser fallback. Leave empty unless BROWSER_FALLBACK_ENABLED=true.
CHROMIUM_EXECUTABLE_PATH=

# Leave empty to disable error screenshots on hosted deployments.
ERROR_SCREENSHOT_PATH=
